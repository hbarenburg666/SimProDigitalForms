# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit it, never paste secrets into chat.

SIMPRO_CLIENT_ID=your_client_id_here
SIMPRO_CLIENT_SECRET=your_client_secret_here

# API base. Default is the Simpro white-label host.
# Fallback if that 404s / fails auth: https://api.gocanvas.com/v3
SIMPRO_BASE_URL=https://digitalforms.simprogroup.com/api/v3

# Optional: the form you're working on (set after running explore.py --list)
SIMPRO_PM_FORM_ID=
